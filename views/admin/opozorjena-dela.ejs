<html>
    <head>
        <meta charset="utf-8">
		<meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
        <link rel="stylesheet" href="/bootstrap/css/bootstrap.min.css">
		<script src="/bootstrap/jquery/jquery.min.js"></script>
		<script src="/bootstrap/popper/popper.min.js"></script>
		<script src="/bootstrap/js/bootstrap.min.js"></script>
        <link rel="stylesheet" href="/css/custom-styles.css">

        <title>FreelanceSLO - Admin - Opozorjena dela</title>

        <script src="/clientside_js/custom-validation.js"></script>

        <script src="/clientside_js/postData.js"></script>
        <script src="/clientside_js/admin-opozorjena-dela.js"></script>
    </head>
    <body class="gf-admin-platform-background">
        <nav class="navbar fixed-top navbar-expand-md navbar-light gf-header-admin shadow-sm">	
			<a class="navbar-brand text-light" href="/index.html">FreelanceSLO</a>

			<button class="navbar-toggler collapsed" type="button" data-toggle="collapse" data-target="#navbarCollapse" aria-controls="navbarCollapse" aria-expanded="false" aria-label="Toggle navigation">
				<span class="navbar-toggler-icon"></span>
			  </button>
			  <div class="navbar-collapse collapse justify-content-end" id="navbarCollapse">
                <a class="btn gf-admin-btn-dark nav-item nav-link text-light m-2" href="/admin/nav/potrjevanje-admin">Administratorji</a>
                <a class="btn gf-admin-btn-dark nav-item nav-link text-light m-2" href="/admin/nav/neprimerna-dela">Dela</a>
                <a class="btn gf-admin-btn-dark nav-item nav-link text-light m-2" href="/admin/nav/prijavljeni-delavci">Delavci</a>
                <a class="btn gf-admin-btn-dark nav-item nav-link text-light m-2" href="/admin/nav/prijavljena-podjetja">Podjetja</a>
    
                <a class="nav-item nav-link text-light" href="/admin/nav/nastavitve"><img class="gf-nav-icon" src="/icon/settings.svg" alt="Nastavitve"><span> Nastavitve</span></a>
                <a class="nav-item nav-link text-light" href="/admin/acc/logout"><img class="gf-nav-icon" src="/icon/logout.svg" alt="Odjava"><span> Odjava</span></a>
			  </div>
		</nav>

        <div class="alert alert-primary shadow-lg d-none" id="status" role="alert">
            <button type="button" onclick="removeElement(this.parentNode)" class="close"><span><span>&times;</span></button>
            <label id="status-text">asdf</label>
        </div>

    <main role="main">
        <div class="container">
            <div id="statusdiv">

            </div>
        <%if (pagedata.prijavljenadela.length == 0) {%>
            <div class="card mt-3 shadow-sm">
                <div class="alert alert-light" role="alert">
                  <h4 class="alert-heading">Bravo!</h4>
                  <hr>
                  <p>Trenutno ni neprimernih del. Osvežite stran za ponoven pregled.</p>
                </div>
            </div>
        <%} else for (delo of pagedata.prijavljenadela) {%>  
            <div id="delo-<%=delo.iddela%>" class="card mt-3 shadow-sm mb-4">
                <div class="card-body">
                    <h5 class="card-title delo-header"><%=delo.naziv%></h5>
                    <h6 class="card-subtitle mb-2 text-muted"><%=delo.imepodrocja%></h6>
                    <h6 class="card-subtitle mb-2 text-muted"><%=delo.placa%>€ / <%=delo.nazivplace%></h6>
                    <h6 class="card-subtitle mb-2 text-muted">Interni id: <%=delo.iddela%></h6>
                <hr>
                <p class="card-text"><%=delo.opis%></p>
                <hr>
                <div class="row">
                    <div class="col-sm">
                  <p class="card-text text-muted delo-details">Izobrazba: <%=delo.nazivizobrazbe%></p>
                  <p class="card-text text-muted delo-details">Spretnosti: <%=delo.spretnosti%></p>
                    </div>
                    <div class="col-sm">
                  <p class="card-text text-muted delo-details">Trajanje: <%=delo.nazivtrajanja%></p>
                  <p class="card-text text-muted delo-details">Delovnik: <%=delo.nazivdelovnika%></p>
                </div>
                </div>
                <hr>
            <div class="mb-4">
                <form>
                <label for="besedilo-prijave">Besedilo odziva:</label>
                <textarea id="razlog-<%=delo.iddela%>" name="besedilo-prijave" class="form-control mb-3"></textarea>
                <button value="<%=delo.iddela%>" onclick="prekiniPrijavo(this)" type="button" class="btn gf-admin-btn mr-2 mb-2">Opusti prijavo</button>
                <button value="<%=delo.iddela%>" onclick="odstraniDelo(this)" type="button" class="btn gf-admin-btn mr-2 mb-2">Opozori delodajalca</button>
                <button value="<%=delo.iddela%>" onclick="dokoncnoIzbrisi(this)" type="button" class="btn btn-danger mr-2 mb-2">Izbriši delo</button>
                <a class="btn gf-admin-btn mr-2 mb-2" data-toggle="collapse" href="#collapseOdzive<%=delo.iddela%>" role="button" aria-expanded="false" aria-controls="collapseOdzive<%=delo.iddela%>">Pokaži odzive..</a>
                </form>
            </div>
            <div class="collapse" id="collapseOdzive<%=delo.iddela%>">
            <%for (prijava of delo.prijave) {%>
                <div class="card mt-2 shadow-sm mb-2">
                <div class="card-body">
                <h5 class="card-title"><%=prijava.ime%> <%=prijava.priimek%></h5>
                <h6 class="text-muted card-subtitle mb-2">Interni id: <%=prijava.iddelavca%></h6>
                <p class="card-text"><%=prijava.besedilo_prijave%></p>
                </div>
                </div>
            <%}%>
            </div>

            </div>
        </div>
        <%}%>
        </main>
    </body>
</html>