<!DOCTYPE html>
<html>
    <head>
        <meta charset="utf-8">
		<meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
        <link rel="stylesheet" href="/bootstrap/css/bootstrap.min.css">
		<script src="/bootstrap/jquery/jquery.min.js"></script>
		<script src="/bootstrap/popper/popper.min.js"></script>
		<script src="/bootstrap/js/bootstrap.min.js"></script>
        <link rel="stylesheet" href="/css/custom-styles.css">

        <script src="/clientside_js/postData.js"></script>
        <script src="/clientside_js/podjetje-nastavitve.js"></script>
        <script src="/clientside_js/podjetje-blokiranje-pritozba.js"></script>
        <script src="/clientside_js/custom-validation.js"></script>
    </head>
    <body class="gf-podjetja-platform-background">
        
        
        <!-- NAVIGACIJA -->

        <nav class="navbar fixed-top navbar-expand-md navbar-light gf-header-podjetja shadow-sm">	
            <a class="navbar-brand text-light" href="/index.html">FreelanceSLO</a>
    
            <button class="navbar-toggler collapsed" type="button" data-toggle="collapse" data-target="#navbarCollapse" aria-controls="navbarCollapse" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
              </button>
              <div class="justify-content-end navbar-collapse collapse " id="navbarCollapse">
                <a class="nav-item nav-link text-light" href="/podjetja/nav/feed/?page=1"><img class="gf-nav-icon" src="/icon/feed.svg" alt="Dela"><span> Dela</span></a>
                <a class="nav-item nav-link text-light" href="/podjetja/nav/nastavitve"><img class="gf-nav-icon" src="/icon/settings.svg" alt="Nastavitve"><span> Nastavitve</span></a>
                <a class="nav-item nav-link text-light" href="/podjetja/acc/logout"><img class="gf-nav-icon" src="/icon/logout.svg" alt="Odjava"><span> Odjava</span></a>
              </div>
        </nav>
        
        <main role="main">
            <div class="container">
                
            <div class="alert alert-primary d-none shadow-lg" id="status" role="alert">
                <button type="button" onclick="removeElement(this.parentNode)" class="close"><span><span>&times;</span></button>
                <label id="status-text"></label>
            </div>

            <% if(userdata.opozorjen == 1) {%>
                <!-- V primeru blokiranja-->
                <div id="opraviciloform" class="card bg-danger">
                <div class="card-body shadow-lg">
                <h1 class="text-white">Vaš račun je bil začasno blokiran zaradi prijave uporabnika.</h1>
    
                <div class="card-header bg-light text-dark">Administrator je priložil razlago:</div>
                <ul class="list-group list-group-flush mb-4">
                    <li class="list-group-item text-dark"><%=userdata.admin_pojasnilo%></li>
                </ul>
        
                <%if (userdata.odgovor_podjetja == null) {%>
                <form>
                    <div class="card-header bg-light text-dark">Če se vam prijava ne zdi pravična, lahko spodaj vpišete razlog in pošljete pritožbo:</div>
                    <ul class="list-group list-group-flush bg-white">
                        <div class="form-group">
                            <textarea placeholder="Prijava se mi ne zdi pravična, saj..." class="form-control gf-to-validate" onchange="validateApology(this)" name="opravicilo" id="opravicilo" type="text"></textarea><br>
                            <div class="ml-2 mb-3"><small class="text-muted text-light">Besedilo lahko vsebuje samo črke, številke in ločila.</small></div>
                            <input type="button" class="btn btn-danger ml-2" onclick="posljiOpravicilo(this);" value="Pošlji">
                        </div>
                    </ul>
                </form>
        
                <%} else {%>
                <div class="card-header bg-light text-dark">Odzvali ste se s sledečim odgovorom:</div>
                <ul class="list-group list-group-flush mb-4">
                    <li class="list-group-item text-dark"><%=userdata.odgovor_podjetja%></li>
                </ul>
                <%}%>
                </div>
                </div>
                <%}%>
            
         <!-- Potrditvene zadevščine-->
         <% if(!userdata.epostapotrjena) {%>
            <div class="card mt-4">
            <div class="card-body shadow-lg">
            <h1>Potrditev e-pošte:</h1>
            <hr>
            
            <div id="potrditevform" class="form-group">
                <label for="potrditvenakoda">Potrditvena koda (poslana na e-poštni naslov vašega računa):</label>
                <input type="text" class="form-control gf-to-validate" onblur="validateEmailCode(this)" id="potrditvenakoda" name="potrditvenakoda">
                <small class="text-muted text-light">Potrditvena koda vsebuje samo števila.</small>
            </div>
            <button class="btn btn-primary m-2" onClick="posljiKodo()">Pošlji</button>
            <button class="btn btn-primary m-2" onclick="getData('/podjetja/acc/eposta-spet',{})">Ponovno pošlji e-pošto.</button>
    
            </div>
            </div>
            <% } %>
            
            <div class="card mt-4">
            <div class="card-body shadow-lg">
            <div class="form-group" id="lastnostiform">

            <h2>Lastnosti računa:</h2>
            <hr>
            <form>
                <div class="form-row">
                <div class="col mb-3">
                <label>Naziv:</label>
                <input class="form-control" id="naziv" name="naziv" onblur="validateCompanyName(this)" type="text" value="<%=userdata.naziv%>">
                <small class="text-muted">Ime podjetja lahko vsebuje samo črke in številke.</small>
                </div>
                <div class="col">
                <label>Vrsta:</label>
                <select class="form-control" id="vrsta">
                    <% for (vrsta of pagedata.vrste) { %>
                    <% if (vrsta.ime == userdata.ime) {%> <option selected="selected" value="<%=vrsta.idvrste%>"><%=vrsta.ime%></option> <%}
                    else {%>    <option value="<%=vrsta.idvrste%>"><%=vrsta.ime%></option> <%}%>
                    <% } %>
                </select>
                </div>
                </div>
                <div class="form-group">
                    <label for="eposta">Epošta:</label>
                    <input name="eposta" class="form-control gf-to-validate" type="text" value="<%=userdata.eposta%>" readonly>
                    <small class="text-muted text-light">E-poštnega naslova računa ni možno spreminjati.</small>
                </div>
                
            </form>
            <button class="btn btn-primary" onclick="posljiPodatke(this)">Pošlji</button>
        </div>
        </div>
        </div>
        <div class="card mt-4">
        <div class="card-body shadow-lg">
        <div id="podjetjeform">
        <h2>Podatki o podjetju:</h2>
        <hr>
        <div class="form-group">
        <label for="velikost">Velikost:</label>
        <select id="velikost" class="form-control" name="velikost">
            <% for (velikost of pagedata.velikosti) { %>
            <% if (velikost.velikost == userdata.velikost) {%> <option selected= "selected" value="<%=velikost.idvelikosti%>"><%=velikost.velikost%> zaposlenih</option> <%}
            else {%>    <option value="<%=velikost.idvelikosti%>"><%=velikost.velikost%> zaposlenih</option> <%}%>
            <% } %>
        </select>
        <small class="text-muted text-light">Poiščite najbližjo velikost.</small>
        </div>

        <div class="form-group">
        <label for="podrocje">Področje:</label>
        <input class="form-control" placeholder="Programiranje, Prepisovanje besedil..." name="podrocje" type="text" id="iskanje-podrocja" value="<%=userdata.imepodrocja%>" oninput="isciPodrocje(this)">
        <small class="text-muted text-light">Vpišite ime ali začetek imena iskanega področja v iskalnik..</small>
        <div id="iskana-podrocja">
        </div>
        </div>

        <div class="form-group">
        <label for="naslov">Naslov:</label><input onblur="validateCompanyName(this)" placeholder="Cesta Andreja Bitenca 31" class="form-control" id="naslov" name="naslov" type="text" value="<%=userdata.naslov%>">
        <small class="text-muted text-light">Naslov lahko vsebuje samo črke in številke.</small>
        </div>

        <div class="form-group">
        <label for="telefonska">Telefonska:</label><input onblur="validatePhoneNumber(this)" placeholder="000-000-000" type="tel" id="telefonska" name="telefonska" class="form-control" value="<%=userdata.telefonska%>">
        <small class="text-muted text-light">Upoštevajte zgornjo obliko.</small>
        </div>

        <div class="form-group">
        <label for="datumzacetka">Datum ustanovitve:</label>
        <input class="form-control" onblur="validateBirthDate(this)" type="date" id="datumzacetka" name="datumzacetka" value="<%=userdata.datum_ustanovitve%>">
        <small class="text-muted text-light">Datum ustanovitve ne sme biti večji od trenutnega datuma.</small>
        </div>
        
        <button class="btn btn-primary mt-2" onclick="posljiPodrobnosti(this)">Posodobi</button>
        
        </div>
        </form>
        </div>
        </div>


        <div class="card mt-4 mb-5">
        <div class="card-body shadow-lg">
            <h2>Izbris računa:</h2>
            <hr>
            <form id="deleteform" method="POST" action="/podjetja/acc/izbris-racuna" enctype="application/x-www-form-urlencoded">
                <div class="form-group">
                    <label for="eposta">Pred izbrisom ponovno vpišite vaš e-poštni naslov.</label>
                    <input class="form-control gf-to-validate" onblur="validateEmail(this)" type="text" name="eposta">
                </div>
                <input class="btn btn-primary mt-2" type="button" onclick="checkForm(document.getElementById('deleteform')); document.getElementById('deleteform').prepend(document.getElementById('status'))" value="Izbriši račun">
            </form>
        </div>
        </div>
        </div>
        </main>
    </body>
</html>